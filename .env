# --- Configurações do VTube Studio ---
VTS_PLUGIN_NAME=Alice VTuber
VTS_DEVELOPER=Mario Alexandre

# Aqui é onde a sua senha super secreta do VTube Studio aparecerá caso autorize o App:
VTS_TOKEN='f2dfd46312531870246fa20b2d6eed2a19175a472150aae3b97de1627def3e79'

# --- Configurações da Inteligência Artificial ---
# Llama3, Qwen2.5, etc
MODELO_IA=llama3.1:8b

# Descrição da voz para o OmniVoice (modo Design de Voz)
# Exemplos: "female, young, soft voice, brazilian portuguese accent"
#           "female, low pitch, calm, portuguese"
VOZ_INSTRUCT=female, young adult, portuguese accent

# --- Configurações de Hardware ---
# Índice do microfone que a Alice vai escutar. Deixe vazio para usar o padrão do sistema.
# Use a aba "🎙️ Áudio" na interface para selecionar visualmente.
INDICE_MICROFONE=1
# Limiar mínimo de volume (RMS) para Alice começar a gravar.
# Aumente se o microfone captar muito ruído ambiente. (Padrão: 500)
LIMIAR_MICROFONE_MINIMO=500

# Dispositivo de saída para o TTS da Alice (nome parcial do dispositivo).
# Deixe em branco para usar o dispositivo padrão do sistema.
DISPOSITIVO_SAIDA_AUDIO='Speakers (3- Fosi Audio K5 Pro)'

# --- Comportamento Proativo ---
# Segundos de silêncio antes de Alice falar espontaneamente (0 = desativado)
TEMPO_PROATIVO=90

# --- ClickHouse (Memória de Interações) ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER_APP=alice
CLICKHOUSE_PASSWORD_APP=alice123
CLICKHOUSE_DB_APP=analytics

# --- Codificação do Terminal ---
# Garante que o terminal Windows lide com caracteres especiais (acentos, etc)
PYTHONIOENCODING=utf-8
INDICE_MICROFONE_2=
DISPOSITIVO_SAIDA_AUDIO_2=
